# Database
DATABASE_URL=postgresql+asyncpg://govtuser:govtpass@localhost:5432/govtschemes

# Redis
REDIS_URL=redis://localhost:6379

# OTP Services
MSG91_API_KEY=your_msg91_api_key_here
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# JWT
JWT_SECRET=change-me-in-production-with-strong-secret
JWT_EXPIRY_HOURS=72

# Groq LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Data Sources
DATA_GOV_API_KEY=your_data_gov_api_key_here
BHASHINI_API_KEY=your_bhashini_api_key_here

# Translation Service
INDICTRANS_URL=http://indictrans:8001/translate

# Backend Configuration
BACKEND_URL=http://localhost:8000
ADMIN_EMAIL=admin@example.com
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
